{
  "name": "opencodeboard",
  "version": "1.0.0",
  "description": "Self-hosted dashboard for monitoring OpenCode Go quota across multiple accounts",
  "license": "MIT",
  "private": false,
  "type": "module",
  "scripts": {
    "build:client": "vite build",
    "build:server": "tsc",
    "build": "npm run build:client && npm run build:server",
    "dev": "vite",
    "dev:server": "tsx watch --env-file .env src/server/index.ts",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "db:migrate": "tsx --env-file .env src/server/migrate.ts"
  },
  "dependencies": {
    "@cloudflare/kumo": "^2.6.0",
    "@phosphor-icons/react": "^2.1.10",
    "better-sqlite3": "^12.11.1",
    "express": "^5.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3",
    "vite": "^7.2.0",
    "vitest": "^4.1.10"
  }
}
